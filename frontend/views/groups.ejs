<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Groupes | SocialVibe</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
</head>

<body class="bg-gray-100 dark:bg-dark-100 text-gray-900 dark:text-white min-h-screen">
    <%- include('partials/navbar') %>
        <%- include('partials/sidebar') %>

            <main class="lg:ml-64 pt-16">
                <div class="max-w-4xl mx-auto px-4 py-6">
                    <div class="flex justify-between items-center mb-6">
                        <h1 class="text-2xl font-bold">Vos groupes</h1>
                        <button class="btn-primary px-4 py-2 rounded-lg text-sm">Créer un groupe</button>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <% const groups=['Développeurs Web', 'Design UX/UI' , 'Startup Life' , 'Voyageurs du Monde' ];
                            %>
                            <% groups.forEach(group=> { %>
                                <div class="bg-white dark:bg-dark-200 rounded-xl shadow-sm p-4 flex items-center gap-4">
                                    <div
                                        class="w-12 h-12 rounded-lg bg-gradient-to-tr from-blue-400 to-purple-500 flex items-center justify-center text-white font-bold text-lg">
                                        <%= group.charAt(0) %>
                                    </div>
                                    <div class="flex-1">
                                        <h3 class="font-semibold">
                                            <%= group %>
                                        </h3>
                                        <p class="text-xs text-gray-500">2.4k membres</p>
                                    </div>
                                    <button
                                        class="text-sm px-3 py-1 bg-gray-100 dark:bg-dark-300 rounded-lg hover:bg-gray-200">Voir</button>
                                </div>
                                <% }); %>
                    </div>
                </div>
            </main>
            <script src="/js/app.js"></script>
</body>

</html>