<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Accueil | SocialVibe</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/output.css">
  <script>
    if (localStorage.getItem('darkMode') === 'true' ||
      (!localStorage.getItem('darkMode') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    }
  </script>
</head>

<body class="bg-gray-100 dark:bg-dark-100 text-gray-900 dark:text-white min-h-screen">

  <%- include('partials/navbar') %>
    <%- include('partials/sidebar') %>

      <!-- Main Content -->
      <main class="lg:ml-64 pt-16">
        <div class="max-w-2xl mx-auto px-4 py-6">

          <!-- Hidden Upload Input for Stories -->
          <input type="file" id="story-upload" class="hidden" accept="image/*">

          <!-- Stories Section -->
          <div class="bg-white dark:bg-dark-200 rounded-xl shadow-md p-4 mb-6 overflow-hidden">
            <div class="flex gap-4 overflow-x-auto pb-2 scrollbar-hide" id="stories-box">
              <!-- Chargement dynamique via feed.js -->
              <div class="flex-shrink-0 flex flex-col items-center">
                <div class="w-16 h-16 rounded-full bg-gray-200 dark:bg-dark-300 animate-pulse"></div>
              </div>
              <div class="flex-shrink-0 flex flex-col items-center">
                <div class="w-16 h-16 rounded-full bg-gray-200 dark:bg-dark-300 animate-pulse"></div>
              </div>
              <div class="flex-shrink-0 flex flex-col items-center">
                <div class="w-16 h-16 rounded-full bg-gray-200 dark:bg-dark-300 animate-pulse"></div>
              </div>
            </div>
          </div>

          <!-- Create Post -->
          <!-- Create Post -->
          <div class="bg-white dark:bg-dark-200 rounded-xl shadow-md p-4 mb-6">
            <div class="flex gap-3">
              <img id="current-user-avatar" src="https://ui-avatars.com/api/?name=User&background=0ea5e9&color=fff"
                alt="Profile" class="current-user-avatar w-10 h-10 rounded-full">
              <div class="flex-1">
                <textarea id="post-content" placeholder="Quoi de neuf ?"
                  class="w-full bg-gray-100 dark:bg-dark-300 rounded-xl px-4 py-3 resize-none focus:outline-none focus:ring-2 focus:ring-primary-500 transition-all"
                  rows="2"></textarea>
                <div class="flex items-center justify-between mt-3">
                  <div class="flex gap-2">
                    <!-- Media Inputs -->
                    <input type="file" id="post-image-input" class="hidden" accept="image/*">
                    <input type="file" id="post-video-input" class="hidden" accept="video/*">

                    <button id="btn-post-image" type="button"
                      class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-dark-300 transition-colors text-primary-500">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </button>
                    <button id="btn-post-video" type="button"
                      class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-dark-300 transition-colors text-green-500">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                      </svg>
                    </button>
                  </div>
                  <button id="btn-publish" class="btn-primary px-6">Publier</button>
                </div>
                <!-- Media Preview -->
                <div id="post-media-preview"
                  class="mt-3 hidden relative rounded-lg overflow-hidden border dark:border-dark-400">
                  <button id="remove-media"
                    class="absolute top-2 right-2 bg-black/50 text-white rounded-full p-1 hover:bg-black/70 z-10">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                  </button>
                  <img id="preview-img" class="max-h-64 w-full object-cover hidden">
                  <video id="preview-video" class="max-h-64 w-full object-cover hidden" controls></video>
                </div>
              </div>
            </div>
          </div>

          <!-- Dynamic Posts Feed -->
          <div id="posts-feed">
            <div class="animate-pulse space-y-6">
              <!-- Skeleton loader -->
              <div class="bg-white dark:bg-dark-200 p-4 rounded-xl h-40"></div>
              <div class="bg-white dark:bg-dark-200 p-4 rounded-xl h-40"></div>
            </div>
          </div>
        </div>
      </main>

      <!-- Right Sidebar - Suggestions -->
      <aside
        class="fixed right-0 top-16 h-[calc(100vh-4rem)] w-80 bg-white dark:bg-dark-200 shadow-lg p-4 hidden xl:block overflow-y-auto">
        <h3 class="font-semibold text-gray-700 dark:text-gray-300 mb-4">Suggestions pour vous</h3>

        <div id="suggestions-box">
          <!-- Chargement dynamique via social.js -->
          <div class="animate-pulse space-y-4">
            <div class="h-10 bg-gray-200 dark:bg-dark-300 rounded-full w-full"></div>
            <div class="h-10 bg-gray-200 dark:bg-dark-300 rounded-full w-full"></div>
            <div class="h-10 bg-gray-200 dark:bg-dark-300 rounded-full w-full"></div>
          </div>
        </div>

        <div class="mt-6">
          <h3 class="font-semibold text-gray-700 dark:text-gray-300 mb-4">Tendances</h3>
          <% const trends=['#TechNews', '#WebDev' , '#Design' , '#Startup' , '#Innovation' ]; %>
            <% trends.forEach((trend, i)=> { %>
              <a href="#"
                class="block py-2 hover:bg-gray-50 dark:hover:bg-dark-300 rounded-lg px-2 -mx-2 transition-colors">
                <p class="font-semibold text-sm text-primary-500">
                  <%= trend %>
                </p>
                <p class="text-xs text-gray-500">
                  <%= (Math.floor(Math.random() * 50) + 10) %>K posts
                </p>
              </a>
              <% }); %>
        </div>
      </aside>

      <!-- Story Viewer Modal -->
      <div id="story-modal"
        class="fixed inset-0 z-50 bg-black bg-opacity-90 hidden flex items-center justify-center backdrop-blur-sm">
        <button id="close-story" class="absolute top-4 right-4 text-white hover:text-gray-300 p-2">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        <div class="relative w-full max-w-md h-[80vh] bg-gray-900 rounded-xl overflow-hidden shadow-2xl">
          <!-- Story Progress Bar -->
          <div class="absolute top-0 left-0 right-0 p-2 flex gap-1 z-10">
            <div class="h-1 flex-1 bg-white/30 rounded-full overflow-hidden">
              <div id="story-progress" class="h-full bg-white w-0 transition-all duration-[5000ms] ease-linear"></div>
            </div>
          </div>

          <!-- Story Header -->
          <div class="absolute top-4 left-4 flex items-center gap-3 z-10">
            <img id="story-avatar" src="" class="w-10 h-10 rounded-full border-2 border-primary-500">
            <div>
              <h4 id="story-username" class="text-white font-semibold text-sm drop-shadow-md"></h4>
              <p class="text-white/80 text-xs shadow-black">Il y a 2h</p>
            </div>
          </div>

          <!-- Story Content -->
          <img id="story-image" src="" class="w-full h-full object-cover">

          <!-- Navigation Areas -->
          <div class="absolute inset-y-0 left-0 w-1/3 z-0" onclick="console.log('Previous story')"></div>
          <div class="absolute inset-y-0 right-0 w-1/3 z-0" onclick="console.log('Next story')"></div>
        </div>
      </div>

      <script src="/js/feed.js"></script>
      <script src="/js/social.js"></script>
      <script src="/js/app.js"></script>
</body>

</html>